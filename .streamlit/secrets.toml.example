# LOC-LOC secrets template.
# Copy this file to  secrets.toml  and fill in your real values.
# secrets.toml is git-ignored so credentials never end up in version control.

[camera]
username    = "your_camera_user"
password    = "your_camera_password"
ip          = "192.168.x.x"        # the camera's CURRENT IP on your network
port        = 554
stream_path = "stream1"            # Tapo C200: stream1 = HD, stream2 = SD

[detection]
# Optional — sensible defaults are built in. Tune for your camera/PC.
model_path     = "yolo26s.pt"      # newest gen (NMS-free, faster CPU). yolo26n.pt=fastest, yolo11s.pt=fallback
device         = "cpu"             # "cuda" if you have an NVIDIA GPU, "mps" on Apple
confidence     = 0.5
infer_imgsz    = 640               # lower (e.g. 480) = faster, less accurate
confirm_frames = 3                 # frames a new person must persist before counting
grace_frames   = 18                # frames a person can vanish before the count drops
target_fps     = 8.0               # inference cap; lower this if CPU usage is high
zone_id        = "book_common_2"

[admin]
password = "lokasyon2026"          # dashboard admin panel password — CHANGE for deploy
